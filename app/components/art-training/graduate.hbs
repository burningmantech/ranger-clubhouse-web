<ModalDialog @title="Graduate candidates" @onEscape={{@onCancel}} @size="xl" as |Modal|>
  <Modal.body>
    {{#if this.isLoading}}
      <LoadingIndicator @text="loading the candidates"/>
    {{else}}
      <p class="text-muted mb-2">
        Granting: <strong>{{this.positionTitles}}</strong>
        {{#if this.fullyGraduatedPosition}}
          &middot; Individuals already holding <strong>{{this.fullyGraduatedPosition.title}}</strong> will be skipped.
        {{/if}}
      </p>

      <div class="d-flex gap-3 mb-3">
        <UiBadge @type="success">{{this.readyCandidates.length}} eligible</UiBadge>
        <UiBadge @type="warning">{{this.overrideCandidates.length}} override</UiBadge>
        <UiBadge @type="secondary">{{this.ineligible.length}} ineligible</UiBadge>
      </div>

      {{#if this.candidates}}
        {{#if this.readyCandidates}}
          <h6>Ready to Graduate</h6>
          <UiTable>
            <thead>
            <tr>
              <th class="w-10 text-center">Graduate?</th>
              <th class="w-20">Callsign</th>
              <th class="w-15">Status</th>
              <th>Result</th>
            </tr>
            </thead>
            <tbody>
            {{#each this.readyCandidates as |candidate|}}
              <tr>
                <td class="text-center">
                  {{#if candidate.didGraduate}}
                    {{fa-icon "check" color="success"}}
                  {{else}}
                    <Input @type="checkbox" @checked={{candidate.selected}}
                           aria-label="Graduate {{candidate.person.callsign}}" />
                  {{/if}}
                </td>
                <td>{{candidate.person.callsign}}</td>
                <td>{{candidate.person.status}}</td>
                <td>{{candidate.reason}}</td>
              </tr>
            {{/each}}
            </tbody>
          </UiTable>
        {{/if}}

        {{#if this.overrideCandidates}}
          <UiNotice @type="warning" @icon="triangle-exclamation" @title="Graduation Override" class="mt-3">
            <p class="mb-2">
              These candidates have not met all requirements. Graduation can be forced but is strongly discouraged.
            </p>
            {{#each this.overrideCandidates as |candidate|}}
              <div class="d-flex align-items-start gap-3 border-top pt-2 mt-2">
                <div class="text-nowrap">
                  {{#if candidate.didGraduate}}
                    {{fa-icon "check" color="success"}}
                  {{else}}
                    <div class="form-check">
                      <Input class="form-check-input" @type="checkbox" @checked={{candidate.selected}}
                             id="override-{{candidate.person.id}}" />
                      <label class="form-check-label fw-semibold"
                             for="override-{{candidate.person.id}}">Force graduate</label>
                    </div>
                  {{/if}}
                </div>
                <div>
                  <strong>{{candidate.person.callsign}}</strong>
                  <UiBadge @type="secondary" class="ms-1">{{candidate.person.status}}</UiBadge>
                  {{#if candidate.reason}}
                    <div class="mt-1">{{candidate.reason}}</div>
                  {{/if}}
                  {{#unless candidate.didGraduate}}
                    <ul class="mb-0 mt-1">
                      {{#each candidate.missingRequirements as |req|}}
                        <li>{{req}}</li>
                      {{/each}}
                    </ul>
                  {{/unless}}
                </div>
              </div>
            {{/each}}
          </UiNotice>
        {{/if}}
      {{else}}
        <p>
          <b class="text-danger">No eligible candidates were found.</b>
        </p>
      {{/if}}

      {{#if this.ineligible}}
        <h6 class="text-muted mt-3">Not Eligible for Graduation</h6>
        <UiTable>
          <thead>
          <tr>
            <th class="w-20">Callsign</th>
            <th class="w-15">Status</th>
            <th>Reason</th>
          </tr>
          </thead>
          <tbody>
          {{#each this.ineligible as |candidate|}}
            <tr>
              <td>{{candidate.person.callsign}}</td>
              <td>{{candidate.person.status}}</td>
              <td>{{candidate.reason}}</td>
            </tr>
          {{/each}}
          </tbody>
        </UiTable>
      {{else if this.candidates}}
        <p class="text-muted mt-3">
          {{fa-icon "circle-check" color="success"}} All candidates are eligible.
        </p>
      {{/if}}
    {{/if}}
  </Modal.body>

  <Modal.footer @align="start">
    {{#unless this.isLoading}}
      <UiButton @onClick={{this.saveGraduateAction}} @disabled={{or (not this.selectedCount) this.isSubmitting}}>
        Graduate {{pluralize this.selectedCount "candidate"}}
      </UiButton>
      <UiCancelButton @disabled={{this.isSubmitting}} @onClick={{@onCancel}} />
      {{#if this.isSubmitting}}
        <LoadingIndicator/>
      {{/if}}
    {{/unless}}
  </Modal.footer>
</ModalDialog>
