<ModalDialog @title="Graduate candidates" @onEscape={{@onCancel}} @size="xl" as |Modal|>
  <Modal.body>
    {{#if this.isLoading}}
      <LoadingIndicator @text="loading the candidates"/>
    {{else}}
      <p>
        Eligible candidates are ones who have passed training, and do not already have the following position(s):<br>
        <b>{{this.positionTitles}}</b>
      </p>
      {{#if this.fullyGraduatedPosition}}
        <p>
          Individuals who already have the <b>{{this.fullyGraduatedPosition.title}}</b>
          position are considered "fully graduated" and will be skipped.
        </p>
      {{/if}}
      {{#if this.candidates}}
        The following candidates are eligible to be granted the position(s):
        <UiTable>
          <thead>
          <tr>
            <th class="w-15 text-center">Graduate?</th>
            <th class="w-15">Callsign</th>
            <th class="w-10">Status</th>
            <th class="w-60">Result</th>
          </tr>
          </thead>

          <tbody>
          {{#each this.candidates as |candidate|}}
            <tr>
              <td class="w-15 text-center">
                {{#if candidate.didGraduate}}
                  {{fa-icon "check" color="success"}}
                {{else}}
                  <Input @type="checkbox" @checked={{candidate.selected}} />
                {{/if}}
              </td>
              <td class="w-15">
                {{candidate.person.callsign}}
              </td>
              <td class="w-15">{{candidate.person.status}}</td>
              <td class="w-50">
                {{candidate.reason}}
                {{#if candidate.missingRequirements}}
                  Has not met the following {{pluralize candidate.missingRequirements.length "requirement"}}:
                  <ul>
                    {{#each candidate.missingRequirements as |req|}}
                      <li>{{req}}</li>
                    {{/each}}
                  </ul>
                  The graduation can be forced through; however, this action is strongly discouraged.
                {{/if}}
              </td>
            </tr>
          {{/each}}
          </tbody>
        </UiTable>
      {{else}}
        <p>
          <b class="text-danger">No eligible candidates were found.</b>
        </p>
      {{/if}}
      {{#if this.ineligible}}
        <div class="text-danger">The following are not eligible for graduation:</div>
        <UiTable>
          <thead>
          <tr>
            <th class="w-15">Callsign</th>
            <th class="w-10">Status</th>
            <th class="w-75">Reason</th>
          </tr>
          </thead>

          <tbody>
          {{#each this.ineligible as |candidate|}}
            <tr>
              <td class="w-15">
                {{candidate.person.callsign}}
              </td>
              <td class="w-10">{{candidate.person.status}}</td>
              <td class="w-75">{{candidate.reason}}</td>
            </tr>
          {{/each}}
          </tbody>
        </UiTable>
      {{else}}
        <p>
          <b class="text-success">No ineligible candidates found. (Congratulations?)</b>
        </p>
      {{/if}}
    {{/if}}
  </Modal.body>

  <Modal.footer @align="start">
    {{#unless this.isLoading}}
      <UiButton @onClick={{this.saveGraduateAction}} @disabled={{or (not this.selectedCount) this.isSubmitting}}>
        Graduate {{pluralize this.selectedCount "candidate"}}
      </UiButton>
      <UiCancelButton @disabled={{this.isSubmitting}} @onClick={{@onCancel}} />
      {{#if this.isSubmitting}}
        <LoadingIndicator/>
      {{/if}}
    {{/unless}}
  </Modal.footer>
</ModalDialog>
