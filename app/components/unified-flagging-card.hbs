<div class="uf-card {{this.severityClass}}">
  {{#if @person.personnel_issue}}
    <div class="uf-flag-banner">
      {{fa-icon "ban" right=1}}
      Personnel flag raised on {{@person.callsign}} &mdash; take no actions until resolved
      {{fa-icon "ban" left=1}}
    </div>
  {{/if}}

  <div class="uf-card-id">
    <div class="uf-card-id-primary">
      <PersonLink @person={{@person}} class="fs-4 fw-semibold" />
      <span class="uf-card-status">&lt;{{@person.status}}&gt;</span>
    </div>
    <div class="uf-card-id-secondary">
      {{@person.first_name}} {{@person.last_name}}
      <span class="uf-card-id-sep">&middot;</span>
      FKA:
      {{#each @person.formerly_known_as as |fka index|}}
        {{~if index ", "~}}{{~fka~}}
      {{else}}
        <i>none</i>
      {{/each}}
    </div>
    {{#if this.sortedPnvHistory}}
      <div class="uf-card-pnv">
        {{#each this.sortedPnvHistory as |entry|}}
          <span class="uf-card-pnv-year">
            <span class="fw-semibold">{{entry.year}}</span>
            {{training-status-badge entry.info.training_status}}
            {{#if entry.info.was_auditor}}
              as auditor
            {{else}}
              {{mentee-status-badge @person.status entry.info.mentor_status entry.info.have_alpha_shift}}
            {{/if}}
          </span>
        {{/each}}
      </div>
    {{/if}}
  </div>

  <IntakeRankStrip @person={{@person}} />

  <div class="uf-card-teams">
    <div class="uf-team">
      <div class="uf-team-label">Personnel</div>
      <IntakeNotes @type="personnel" @person={{@person}} @viewYear={{@year}} @onSubmit={{@onSubmit}} />
    </div>
    <div class="uf-team">
      <div class="uf-team-label">RRN</div>
      <IntakeNotes @type="rrn" @person={{@person}} @viewYear={{@year}} @onSubmit={{@onSubmit}} />
    </div>
    <div class="uf-team">
      <div class="uf-team-label">VC</div>
      <IntakeNotes @type="vc" @person={{@person}} @viewYear={{@year}} @onSubmit={{@onSubmit}} />
    </div>
    <div class="uf-team">
      <div class="uf-team-label">Training</div>
      <IntakeTraining @trainings={{@person.trainings}} @person={{@person}} />
    </div>
    <div class="uf-team">
      <div class="uf-team-label">Mentor</div>
      <IntakeNotes @type="mentor" @person={{@person}} @viewYear={{@year}} @onSubmit={{@onSubmit}} />
    </div>
  </div>
</div>
