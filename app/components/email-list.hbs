<div class="mt-2">
  <a href id="{{this.listId}}-link"
     class="btn btn-secondary btn-sm"
    {{on "click" this.copyToClipboardAction}}>
    Copy {{pluralize @people.length "email"}} to clipboard
  </a>
</div>
{{#if this.showWarning}}
  <PersonalInfoWarning />
{{/if}}
<div id={{this.listId}} class="mt-2" {{on-insert this.elementInserted}}>
  {{~#each @people as |person idx|~}}
    {{~#if idx}},<br>{{/if}}"{{person.callsign}}" &lt;{{person.email}}&gt;
  {{~/each~}}
</div>
