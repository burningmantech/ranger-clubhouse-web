<h1>Unclaimed Expiring Tickets</h1>

<p>Below are unclaimed tickets that will expire at the end of the coming event.</p>

Showing {{pluralize this.expiring.length "person"}}
<div>
  <UiButton @type="secondary" @size="sm" @onClick={{this.exportCSV}}>
    {{fa-icon "file-export"}} Export CSV
  </UiButton>
</div>
<UiTable>
  <thead>
    <tr>
      <th>Callsign</th>
      <th>Status</th>
      <th>Email</th>
      <th>RAD</th>
      <th>Ticket Type</th>
      <th>Ticket Status</th>
      <th>Good Through</th>
    </tr>
  </thead>

  <tbody>
    {{#each this.expiringRows as |row|}}
      <tr>
        <td><PersonLink @person={{row.person}} @page="tickets-provisions" /></td>
        <td>{{row.person.status}}</td>
        <td><MailTo @to={{row.person.email}} /></td>
        <td>{{row.rad}}</td>
        <td>{{row.ticket_type}}</td>
        <td>{{row.ticket_status}}</td>
        <td>{{row.good_through}}</td>
      </tr>
    {{else}}
      <tr>
        <td colspan="7" class="text-danger">
          Huh, I could not find any expiring tickets for this year.
        </td>
      </tr>
    {{/each}}
  </tbody>
</UiTable>

<EmailList @people={{this.emailList}} />
