<h1>Unclaimed Tickets With Sign Ups</h1>
{{! TODO: 'August 15th' is hardcoded here and independently in the API's }}
{{! UnclaimedTicketsWithSignupsReport.php ($year-08-15). These share no source }}
{{! of truth and will silently drift. The API should return the cutoff date }}
{{! (e.g. signup_cutoff) so it can be rendered here instead of hardcoded. }}
<p>
  This report shows all unclaimed tickets, and if a person is signed up for a shift starting on or after August 15th.
</p>
<p>
  <UiExportToCSVButton @onClick={{this.exportToCSV}} />
</p>
{{pluralize this.tickets.length "ticket"}} found.
<UiTable>
  <thead>
  <tr>
    <th>Callsign</th>
    <th>Status</th>
    <th>Email</th>
    <th>Type</th>
    <th>RAD</th>
    <th>Expires On</th>
    <th>Has Signup?</th>
  </tr>
  </thead>
  <tbody>
  {{#each this.tickets as |ticket|}}
    <tr>
      <td>
        <PersonLink @person={{ticket}} />
      </td>
      <td>
        {{ticket.status}}
      </td>
      <td>
        <MailTo @to={{ticket.email}} />
      </td>
      <td>
        {{ticket-type-human ticket.type}}
      </td>
      <td>
        RAD-{{ticket.access_document_id}}
      </td>
      <td>
        {{ticket.expiry_date}}
      </td>
      <td class="text-center">
        {{yesno ticket.has_signup}}
      </td>
    </tr>
  {{/each}}
  </tbody>
</UiTable>