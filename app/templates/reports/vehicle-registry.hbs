<YearSelect @title="Vehicle Registry"
            @year={{this.year}}
            @minYear={{2019}}
            @onChange={{set-value this 'year'}}
/>

<UiSection>
  <:title>
    {{this.year}} Vehicle Registry
    <span class="text-muted ms-2 fs-6 fw-normal">
      {{this.viewVehicles.length}} of {{pluralize this.person_vehicle.length "vehicle"}}
    </span>
  </:title>
  <:actions>
  </:actions>
  <:body>
    <div class="vr-filter-bar mb-3">
      <div class="vr-filter-group">
        <label class="form-label mb-0 small">Status</label>
        <ChForm::Select @name="filter"
                        @value={{this.filter}}
                        @options={{this.filterOptions}}
                        @onChange={{set-value this 'filter'}} />
      </div>
      <div class="vr-filter-group">
        <label class="form-label mb-0 small">Type</label>
        <ChForm::Select @name="typeFilter"
                        @value={{this.typeFilter}}
                        @options={{this.filterTypeOptions}}
                        @onChange={{set-value this 'typeFilter'}} />
      </div>
      <div class="vr-filter-group vr-filter-search">
        <label class="form-label mb-0 small">Rental / Driving / License #</label>
        <div class="input-group">
          <span class="input-group-text">{{fa-icon "search"}}</span>
          <Input @type="text" @value={{this.numberFilter}} class="form-control" placeholder="Search..."/>
          {{#if this.numberFilter}}
            <button type="button" class="btn btn-outline-secondary" {{on "click" this.clearNumberFilterAction}}>
              {{fa-icon "times"}}
            </button>
          {{/if}}
        </div>
      </div>
    </div>

    {{#if this.canEditVehicles}}
      <UiButtonRow class="mb-3">
        <UiButton @onClick={{this.newEditAction}} @size="sm">New Vehicle</UiButton>
        <UiExportToCSVButton @onClick={{this.exportToCSV}} />
      </UiButtonRow>
    {{/if}}

    {{!-- Desktop table (xl+) --}}
    <div class="vr-table d-none d-xl-block">
      <div class="vr-header">
        <div class="vr-col-person">Person/Team</div>
        <div class="vr-col-status">Status</div>
        <div class="vr-col-vehicle">Vehicle</div>
        <div class="vr-col-permit">Permit &amp; IDs</div>
        <div class="vr-col-items">Items</div>
        <div class="vr-col-action">Action</div>
      </div>
      {{#each this.viewVehicles as |vehicle|}}
        <div class="vr-row {{if vehicle.isFleet "vr-fleet" "vr-personal"}}">
          <div class="vr-col-person">
            {{#if vehicle.isPersonal}}
              <PersonLink @person={{vehicle.person}} />
            {{else if vehicle.team_assignment}}
              Team {{vehicle.team_assignment}}
            {{else}}
              <i>Fleet Vehicle</i>
            {{/if}}
          </div>
          <div class="vr-col-status">
            {{#if vehicle.isApproved}}
              <UiBadge @type="success">approved</UiBadge>
            {{else if vehicle.isRejected}}
              <UiBadge @type="danger">denied</UiBadge>
            {{else if vehicle.isPending}}
              <UiBadge @type="secondary">pending</UiBadge>
            {{else}}
              {{vehicle.status}}
            {{/if}}
          </div>
          <div class="vr-col-vehicle">
            {{vehicle.vehicle_year}} {{vehicle.vehicle_make}} {{vehicle.vehicle_model}} {{vehicle.vehicle_color}}<br>
            {{vehicle.vehicle_class}}<br>
            {{vehicle.license_state}}-{{vehicle.license_number}}
          </div>
          <div class="vr-col-permit">
            {{#if vehicle.isRejected}}
              -
            {{else}}
              {{vehicle.drivingStickerLabel}}
              {{#if vehicle.sticker_number}}
                #{{vehicle.sticker_number}}
              {{/if}}
            {{/if}}
            <br>
            <PresentOrNot @value={{vehicle.rental_number}} @empty="-"/>
          </div>
          <div class="vr-col-items">
            {{#if vehicle.isRejected}}
              -
            {{else}}
              {{#if (not-eq vehicle.ranger_logo "none")}}
                <span class="vr-item-pill">{{vehicle.rangerLogoLabel}}</span>
              {{/if}}
              {{#if (not-eq vehicle.fuel_chit "none")}}
                <span class="vr-item-pill">{{vehicle.fuelChitLabel}}</span>
              {{/if}}
              {{#if (not-eq vehicle.amber_light "none")}}
                <span class="vr-item-pill">{{vehicle.amberLightLabel}}</span>
              {{/if}}
              {{#if vehicle.org_vehicle_insurance}}
                <span class="vr-item-pill vr-item-mvr">MVR</span>
              {{/if}}
              {{#if vehicle.signed_motorpool_agreement}}
                <span class="vr-item-pill vr-item-mp">Motor Pool</span>
              {{/if}}
              {{#if (not (or
                (not-eq vehicle.ranger_logo "none")
                (not-eq vehicle.fuel_chit "none")
                (not-eq vehicle.amber_light "none")
                vehicle.org_vehicle_insurance
                vehicle.signed_motorpool_agreement
              ))}}
                -
              {{/if}}
            {{/if}}
          </div>
          <div class="vr-col-action">
            <UiButtonRow>
              {{#if this.canEditVehicles}}
                <UiEditButton @type="secondary" @size="sm"
                              @onClick={{fn this.editEntryAction vehicle}} />
              {{/if}}
              <UiButton @type="secondary" @size="sm"
                        @onClick={{fn this.editStickerAction vehicle}}>
                Permit
              </UiButton>
            </UiButtonRow>
          </div>
        </div>
      {{else}}
        <div class="vr-row">
          <UiEmptyState @icon="car"
                        @title="No vehicles found"
                        @description={{if this.person_vehicle
                                          (concat "No " this.year " vehicles matched the criteria.")
                                          (concat "No " this.year " vehicles were found.")
          }} />
        </div>
      {{/each}}
    </div>

    {{!-- Mobile card list (below xl) --}}
    <div class="vr-card-list d-xl-none">
      {{#each this.viewVehicles as |vehicle|}}
        <div class="vr-card {{if vehicle.isFleet "vr-fleet" "vr-personal"}}">
          <div class="vr-card-header">
            <div class="vr-card-owner">
              {{#if vehicle.isPersonal}}
                <PersonLink @person={{vehicle.person}} />
              {{else if vehicle.team_assignment}}
                Team {{vehicle.team_assignment}}
              {{else}}
                <i>Fleet Vehicle</i>
              {{/if}}
            </div>
            <div>
              {{#if vehicle.isApproved}}
                <UiBadge @type="success">approved</UiBadge>
              {{else if vehicle.isRejected}}
                <UiBadge @type="danger">denied</UiBadge>
              {{else if vehicle.isPending}}
                <UiBadge @type="secondary">pending</UiBadge>
              {{else}}
                {{vehicle.status}}
              {{/if}}
              {{#if vehicle.isFleet}}
                <UiBadge @type="info" class="ms-1">Fleet</UiBadge>
              {{/if}}
            </div>
          </div>
          <div class="vr-card-vehicle">
            {{vehicle.vehicle_year}} {{vehicle.vehicle_make}} {{vehicle.vehicle_model}} {{vehicle.vehicle_color}}
            | {{vehicle.vehicle_class}}
            | {{vehicle.license_state}}-{{vehicle.license_number}}
          </div>
          {{#unless vehicle.isRejected}}
            <div class="vr-card-permit-row">
              Permit: {{vehicle.drivingStickerLabel}}
              {{#if vehicle.sticker_number}}
                #{{vehicle.sticker_number}}
              {{/if}}
            </div>
          {{/unless}}
          <div class="vr-card-actions">
            <UiButton @type="primary" @size="sm"
                      @onClick={{fn this.editStickerAction vehicle}}>
              {{fa-icon "plus" right=1}} View / Add Permit
            </UiButton>
            {{#if this.canEditVehicles}}
              <UiEditButton @type="secondary" @size="sm"
                            @onClick={{fn this.editEntryAction vehicle}} />
            {{/if}}
          </div>
          <details class="vr-card-details">
            <summary>More details</summary>
            <div class="vr-card-details-grid">
              <span class="text-muted">DPW Req. ID</span>
              <span><PresentOrNot @value={{vehicle.rental_number}} @empty="-"/></span>
              {{#unless vehicle.isRejected}}
                <span class="text-muted">Ranger Logo</span>
                <span>{{vehicle.rangerLogoLabel}}</span>
                <span class="text-muted">Fuel Chit</span>
                <span>{{vehicle.fuelChitLabel}}</span>
                <span class="text-muted">Amber Light</span>
                <span>{{vehicle.amberLightLabel}}</span>
                <span class="text-muted">MVR</span>
                <span>{{if vehicle.org_vehicle_insurance "Yes" "-"}}</span>
                <span class="text-muted">Motor Pool</span>
                <span>{{if vehicle.signed_motorpool_agreement "Yes" "-"}}</span>
              {{/unless}}
            </div>
          </details>
        </div>
      {{else}}
        <UiEmptyState @icon="car"
                      @title="No vehicles found"
                      @description={{if this.person_vehicle
                                        (concat "No " this.year " vehicles matched the criteria.")
                                        (concat "No " this.year " vehicles were found.")
        }} />
      {{/each}}
    </div>
  </:body>
</UiSection>

{{#if this.editEntry}}
  <VehicleRegistry::FullEdit @entry={{this.editEntry}}
                             @saveAction={{this.saveEditAction}}
                             @cancelAction={{this.cancelEditAction}}
                             @deleteAction={{this.deleteAction}}
  />
{{/if}}

{{#if this.stickerEditEntry}}
  <VehicleRegistry::StickerEdit @entry={{this.stickerEditEntry}}
                                @saveAction={{this.saveStickerAction}}
                                @cancelAction={{this.cancelStickerAction}}
  />
{{/if}}