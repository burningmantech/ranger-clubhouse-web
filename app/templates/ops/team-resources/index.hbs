<h1>Team Resource Document Management</h1>
{{#if this.teams}}
  <p>
    You are allowed to maintain resource documents for the following {{pluralize this.teams.length "team"}}. Click on a team title to manage that team's document.
  </p>

  <div class="masonry-container masonry-hover">
    {{#each this.teams as |team|}}
      <LinkTo @route="ops.team-resources.manage" @model={{team.id}} class="masonry-item py-2">
        {{team.title}}
      </LinkTo>
    {{/each}}
  </div>
{{else}}
  <div class="text-danger">You appear not to have any resource document management permissions for any Clubhouse Team.</div>
{{/if}}
