{{#if this.person.isPastProspective}}
  <DashboardPastProspective/>
{{else if this.person.isBonked}}
  <DashboardBonked/>
{{else if this.person.isProspectiveWaitlist}}
  <DashboardProspectiveWaitlist/>
{{else if (or this.person.isProspective this.person.isAlpha)}}
  <DashboardPnv @milestones={{this.milestones}}
                @person={{this.person}}
                @photo={{this.photo}}
                @motds={{this.motds}}
                @uploadAction={{this.showUploadDialogAction}}
                @agreements={{this.agreements}}
                @debugUpdateAction={{this.debugUpdateAction}} />
{{else if this.person.isAuditor}}
  <DashboardAuditor @milestones={{this.milestones}}
                    @person={{this.person}}
                    @motds={{this.motds}}
                    @agreements={{this.agreements}}
                    @debugUpdateAction={{this.debugUpdateAction}} />
{{else}}
  {{#if this.signinPositions}}
    <UiNotice @type="secondary" @title="Sign in before you volunteer for certain positions" @icon="person-walking">
      <div class="lh-2">
        To volunteer any of the following positions, you need to be signed in to it.<br>
        Signing in gives you the Clubhouse permissions that position requires.<br>
        <b>No one around to sign you in?</b> Call Khaki.
      </div>
      <ul class="mt-2 mb-0">
        {{#each this.signinPositions as |pos|}}
          <li>{{pos.title}}</li>
        {{/each}}
      </ul>
    </UiNotice>
  {{/if}}
  <DashboardRanger @milestones={{this.milestones}}
                   @person={{this.person}}
                   @motds={{this.motds}}
                   @photo={{this.photo}}
                   @uploadAction={{this.showUploadDialogAction}}
                   @agreements={{this.agreements}}
                   @debugUpdateAction={{this.debugUpdateAction}}
  />
{{/if}}

<UiSection id="contacts">
  <:title>Who To Contact For Help</:title>
  <:body>
    {{!template-lint-disable no-triple-curlies}}
    {{{this.milestones.contacts}}}
  </:body>
</UiSection>

{{#if this.showUploadDialog}}
  <PhotoUpload @person={{this.person}}
               @photo={{this.photo}}
               @refreshPhoto={{this.refreshPhoto}}
               @closeAction={{this.closeUploadDialogAction}} />
{{/if}}
