<h1>Agreements &amp; Documents</h1>
<BackToHome/>

{{#if this.showTeam}}
  <h2>{{this.showTeam.title}} Info Document</h2>
  {{!template-lint-disable no-triple-curlies}}
  {{{this.showTeam.document_body}}}
  <div class="mt-2">
    <UiCloseButton @onClick={{this.closeTeamDocument}} />
  </div>
{{else if this.showAgreementForSigning}}
  <Me::DocumentReview @tag={{this.showAgreementForSigning.tag}} @onClose={{this.closeAgreementToSign}} />
{{else if this.showAgreementToView}}
  <h2>{{this.showAgreementToView.title}}</h2>
  <DocumentShow @tag={{this.showAgreementToView.tag}} />
  <div class="mt-2">
    <UiCloseButton @onClick={{this.closeAgreementView}} />
  </div>
{{else}}
  <UiSection>
    <:title>BRC Ranger &amp; Burning Man Project Agreements</:title>
    <:body>
      <p>
        Click on the button to review and optionally sign the document:
      </p>
      {{#each this.agreements as |agreement|}}
        <div class="card mb-3">
          <div class="card-body">
            <h5 class="card-title">
              {{agreement.title}}
            </h5>
            <div class="card-text">
              {{#if agreement.available}}
                {{#if agreement.signed}}
                  <p>
                    <span class="text-success">{{fa-icon "check" right=1}} You have agreed to this document.</span>
                  </p>
                  <UiButton @onClick={{fn this.showAgreement agreement}} @type="secondary">
                    View Agreement
                  </UiButton>
                {{else}}
                  <p>
                    Please review and agree to the document.
                  </p>
                  <UiButton @onClick={{fn this.reviewAgreementToSign agreement}}>
                    Review Agreement &amp; Sign
                  </UiButton>
                {{/if}}
              {{else}}
                <span class="text-muted">{{fa-icon "hand" right=1}} Check back later, the document is not available to sign at the moment.</span>
              {{/if}}
            </div>
          </div>
        </div>
      {{else}}
        There are no agreements available to view or sign. Check back later.
      {{/each}}
    </:body>
  </UiSection>

  <UiSection>
    <:title>Ranger Team Info Documents</:title>
    <:body>
      <p>
        Each Ranger team you belong to may publish a general info document about its volunteer work. Your team may also
        keep extra documents on its Google Drive (or similar).
      </p>

      {{#each this.teams as |team|}}
        <div class="card mb-3">
          <div class="card-body">
            <h5 class="card-title">
              {{team.title}} Info Document
            </h5>
            <div class="card-text">
              <UiButton @onClick={{fn this.openTeamDocument team}} @type="secondary">View Document</UiButton>
            </div>
          </div>
        </div>
      {{else}}
        No team documents found
      {{/each}}
    </:body>
  </UiSection>
{{/if}}
