<YearSelect @title="Post Season Summary"
            @year={{this.year}}
            @minYear={{2008}}
            @skipPandemic={{true}}
            @onChange={{set-value this 'year'}}  />

<div class="roster-controls post-season-filters">
  <span class="fw-semibold">Filter By:</span>
  <ChForm::Select @name="signup-filter" @options={{this.signupOptions}} @value={{this.signupFilter}}
                  @onChange={{set-value this 'signupFilter'}} @controlClass="form-select w-auto" />
  <ChForm::Select @name="status-filter" @options={{this.statusOptions}} @value={{this.statusFilter}}
                  @onChange={{set-value this 'statusFilter'}} @controlClass="form-select w-auto" />
  <ChForm::Select @name="rank-filter" @options={{this.rankOptions}} @value={{this.rankFilter}}
                  @onChange={{set-value this 'rankFilter'}} @controlClass="form-select w-auto" />
  <ChForm::Select @name="notes-filter" @options={{this.notesOptions}} @value={{this.notesFilter}}
                  @onChange={{set-value this 'notesFilter'}} @controlClass="form-select w-auto" />
  <label class="d-flex align-items-center gap-1 fw-semibold mb-0">
    Mentors
    <ChForm::Select @name="mentor-filter" @options={{this.mentorOptions}} @value={{this.selectedMentorIds}}
                    @multiple={{true}} @size={{4}} @onChange={{this.updateSelectedMentorIds}}
                    @controlClass="form-select" />
  </label>
  <label class="d-flex align-items-center gap-1 fw-semibold mb-0">
    Applicant Callsign
    <Input @type="text" @value={{this.callsignFilter}} class="form-control post-season-callsign" />
  </label>
  <span class="roster-controls-count ms-auto">Showing {{this.filteredMentees.length}} of {{this.mentees.length}}</span>
</div>

{{#if this.filteredMentees.length}}
  <div class="post-season-summary">
    {{#if this.flaggedMentees.length}}
      <div class="uf-row-section">
        <div class="uf-row-section-title">Bonked or Mentor Rank 3/4</div>
        <div class="uf-row-stack">
          {{#each this.flaggedMentees key="id" as |mentee|}}
            <div class="uf-row">
              <div class="uf-row-anchor">
                <div class="uf-row-head">
                  <div class="uf-row-identity">
                    <PersonLink @person={{mentee}} class="uf-callsign"/>
                    <span class="uf-card-status">&lt;{{mentee.status}}&gt;</span>
                    <span class="badge uf-row-badge text-bg-{{mentee.alphaColor}}">{{mentee.alphaLabel}}</span>
                    {{#if mentee.mentorRankFlagged}}
                      {{#if (eq mentee.mentorRank 4)}}
                        <IntakeChip @rank={{4}} @label="Rank 4/FLAG" @icon="flag" />
                      {{else}}
                        <IntakeChip @rank={{3}} @label="Rank 3/Yellow" @icon="bell" />
                      {{/if}}
                    {{/if}}
                  </div>
                </div>
                <div class="uf-row-meta">
                  <span class="fw-semibold">Mentors:</span>
                  {{#each mentee.mentors as |mentor idx| ~}}
                    {{#if idx}} / {{/if}}
                    <PersonLink @person={{mentor}} />
                  {{else}}
                    <i>none</i>
                  {{/each}}
                </div>
              </div>
              <div class="uf-row-detail">
                <IntakeNotes @type="mentor" @person={{mentee}} @viewYear={{this.year}} @onSubmit={{this.noteSubmitted}} />
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    {{#if this.otherMentees.length}}
      <div class="uf-row-section">
        <div class="uf-row-section-title">Other Mentees</div>
        <div class="uf-row-stack">
          {{#each this.otherMentees key="id" as |mentee|}}
            <div class="uf-row">
              <div class="uf-row-anchor">
                <div class="uf-row-head">
                  <div class="uf-row-identity">
                    <PersonLink @person={{mentee}} class="uf-callsign"/>
                    <span class="uf-card-status">&lt;{{mentee.status}}&gt;</span>
                    <span class="badge uf-row-badge text-bg-{{mentee.alphaColor}}">{{mentee.alphaLabel}}</span>
                    {{#if mentee.mentorRankFlagged}}
                      {{#if (eq mentee.mentorRank 4)}}
                        <IntakeChip @rank={{4}} @label="Rank 4/FLAG" @icon="flag" />
                      {{else}}
                        <IntakeChip @rank={{3}} @label="Rank 3/Yellow" @icon="bell" />
                      {{/if}}
                    {{/if}}
                  </div>
                </div>
                <div class="uf-row-meta">
                  <span class="fw-semibold">Mentors:</span>
                  {{#each mentee.mentors as |mentor idx| ~}}
                    {{#if idx}} / {{/if}}
                    <PersonLink @person={{mentor}} />
                  {{else}}
                    <i>none</i>
                  {{/each}}
                </div>
              </div>
              <div class="uf-row-detail">
                <IntakeNotes @type="mentor" @person={{mentee}} @viewYear={{this.year}} @onSubmit={{this.noteSubmitted}} />
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}
  </div>
{{else}}
  <p>
    <b class="text-danger">
      {{#if this.mentees.length}}
        No mentees matched the filter criteria{{#if this.filterNames}} of {{join this.filterNames ", "}}{{/if}}.
      {{else}}
        No mentees found for {{this.year}}.
      {{/if}}
    </b>
  </p>
{{/if}}
