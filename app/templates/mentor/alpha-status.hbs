<h1>{{this.year}} Prospective And Alpha Status</h1>

{{! ── Legend card (safety-critical instruction reads first) ── }}
<div class="roster-legend">
    <span class="roster-legend-label">Legend:</span>
    <span class="roster-legend-item">
        {{fa-icon "exclamation-triangle" color="danger"}}
        Personnel Black Flag Raised &mdash; take no actions until resolved.
    </span>
</div>

{{! ── Controls bar (Filter select + live count pill) ── }}
<div class="roster-controls">
    <div class="d-flex align-items-center gap-2">
        <span class="fw-semibold small">Filter:</span>
        <ChForm::Select @name="filter"
                        @value={{this.filter}}
                        @options={{this.filterOptions}}
                        @onChange={{set-value this 'filter'}}
                        @fieldSize="sm" />
    </div>
    <div class="roster-controls-divider"></div>
    <span class="roster-controls-count">
        Showing {{this.viewPotentials.length}} of {{this.mentees.length}}
    </span>
</div>

<p class="roster-info-note">
    <span class="me-3">Current alphas: <strong>{{this.alphaCount}}</strong></span>
    <span class="me-3">Status eligible: <strong>{{this.statusEligibleCount}}</strong></span>
    <span>Position eligible: <strong>{{this.positionEligibleCount}}</strong></span>
</p>
<div class="table-responsive">
<UiTable>
    <thead>
    <tr>
        <th>Callsign</th>
        <th>Name</th>
        <th>Status</th>
        <th>Mentor Issue<br>(Rank >=3)</th>
        <th class="text-center">Trained?</th>
        <th class="text-center">Is Alpha?</th>
    </tr>
    </thead>
    <tbody>
    {{#each this.sections key="key" as |section|}}
        <tr class="alpha-section-header {{if section.isAttention "alpha-section-attention"}}">
            <th colspan="7">
                {{#if section.collapsible}}
                    <button type="button" class="alpha-section-toggle"
                            aria-expanded="{{unless section.collapsed "true" "false"}}"
                            {{on "click" (fn this.toggleSection section.key)}}>
                        {{fa-icon (if section.collapsed "chevron-right" "chevron-down") right=1}}
                        {{section.title}}
                        <span class="alpha-section-count">({{section.people.length}})</span>
                    </button>
                {{else}}
                    {{#if section.isAttention}}{{fa-icon "exclamation-triangle" right=1}}{{/if}}
                    {{section.title}}
                    <span class="alpha-section-count">({{section.people.length}})</span>
                {{/if}}
            </th>
        </tr>
        {{#unless section.collapsed}}
            {{#each section.people key="id" as |person|}}
                <AlphaStatusRow @person={{person}} />
            {{/each}}
        {{/unless}}
    {{/each}}

    {{#unless this.viewPotentials.length}}
        <tr>
            <td colspan="7">
                {{#if this.mentees.length}}
                    <b class="text-danger">No Alphas or Prospectives matched the filter criteria.</b>
                {{else}}
                    <b class="text-danger">No Alpha or Prospectives were found for {{this.year}}.</b>
                {{/if}}
            </td>
        </tr>
    {{/unless}}
    </tbody>
</UiTable>
</div>
